{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exora.dev/contracts/exora.operation-validation-plan.v3.schema.json",
  "title": "Exora Operation Validation Plan v3",
  "type": "object",
  "required": ["schemaVersion", "apiId", "operationId", "operationSha256", "openapiSha256", "planSha256", "checks"],
  "properties": {
    "schemaVersion": { "const": "exora.operation-validation-plan.v3" },
    "apiId": { "type": "string" },
    "operationId": { "type": "string" },
    "operationSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "openapiSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "planSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "checks": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["id", "category", "type"] } }
  }
}
