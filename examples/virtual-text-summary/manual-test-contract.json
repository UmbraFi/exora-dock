{
  "schemaVersion": "exora.api-contract.v1",
  "capability": {
    "schemaVersion": "exora.api.v3",
    "title": "Virtual Text Summary API",
    "description": "Summarize submitted text through a local deterministic test API. This fixture is safe to run repeatedly and exists only to exercise the Exora contract workflow.",
    "deliveryMode": "local_dock",
    "runtime": {
      "publicBaseUrl": "http://127.0.0.1:3000",
      "healthPath": "/health"
    },
    "interface": {
      "openapi": "3.1.0",
      "info": {
        "title": "Virtual Text Summary API",
        "version": "1.0.0",
        "description": "Local deterministic service for manually testing contract validation."
      },
      "paths": {
        "/summarize": {
          "post": {
            "operationId": "summarize_text",
            "summary": "Summarize submitted text",
            "description": "Returns a deterministic concise summary and input-character usage.",
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "text"
                    ],
                    "properties": {
                      "text": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 100000,
                        "description": "UTF-8 source text to summarize."
                      }
                    }
                  }
                }
              }
            },
            "responses": {
              "200": {
                "description": "Summary generated",
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "summary",
                        "usage"
                      ],
                      "properties": {
                        "summary": {
                          "type": "string",
                          "minLength": 1,
                          "description": "Generated summary; validation does not assert its exact wording."
                        },
                        "usage": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": [
                            "inputCharacters"
                          ],
                          "properties": {
                            "inputCharacters": {
                              "type": "integer",
                              "minimum": 1,
                              "maximum": 100000
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "400": {
                "description": "Invalid text input",
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "error",
                        "message"
                      ],
                      "properties": {
                        "error": {
                          "const": "invalid_text"
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "operations": [
      {
        "schemaVersion": "exora.operation.v3",
        "operationId": "summarize_text",
        "title": "Summarize Text",
        "description": "Accept non-empty text and return a concise summary. Validation checks protocol and schema rather than exact summary wording.",
        "enabled": true,
        "usage": {
          "useCases": [
            "Condense a paragraph for a preview.",
            "Exercise the complete local Provider contract workflow."
          ],
          "instructions": [
            "Send UTF-8 source text in the JSON text field.",
            "The text field must contain at least one non-whitespace character.",
            "Read the generated summary from response.summary."
          ]
        },
        "api": {
          "method": "POST",
          "path": "/summarize",
          "openapiOperationRef": "#/paths/~1summarize/post",
          "errors": [
            {
              "code": "invalid_text",
              "httpStatus": 400,
              "description": "The text field is missing, empty, or whitespace-only.",
              "retryable": false
            }
          ]
        },
        "behavior": {
          "sideEffect": {
            "present": false,
            "description": "The call does not modify external state.",
            "reversible": false,
            "testMode": "none"
          },
          "idempotency": {
            "supported": true,
            "retentionSeconds": 86400
          }
        },
        "interaction": {
          "mode": "request_response"
        },
        "limits": {
          "timeoutSeconds": 30,
          "maximumRequestBytes": 1048576,
          "maximumResponseBytes": 1048576,
          "maximumConcurrency": 4
        },
        "metering": {
          "capabilities": []
        },
        "qualification": {
          "fixtures": [
            {
              "id": "summary_success",
              "kind": "success",
              "description": "Checks the success status, media type, and complete response schema.",
              "request": {
                "body": {
                  "text": "Exora validates API contracts and settlement behavior."
                }
              },
              "expectedProtocol": {
                "status": 200,
                "mediaType": "application/json",
                "openapiResponseRef": "#/paths/~1summarize/post/responses/200"
              },
              "safeToRepeat": true
            },
            {
              "id": "summary_invalid_text",
              "kind": "business_error",
              "errorCode": "invalid_text",
              "description": "Whitespace satisfies the request type but is rejected as the declared business error.",
              "request": {
                "body": {
                  "text": "   "
                }
              },
              "expectedProtocol": {
                "status": 400,
                "mediaType": "application/json",
                "openapiResponseRef": "#/paths/~1summarize/post/responses/400"
              },
              "safeToRepeat": true
            }
          ]
        },
        "dataPolicy": {
          "inputHandling": "transient",
          "retentionSeconds": 0
        }
      }
    ]
  },
  "billing": [
    {
      "operationId": "summarize_text",
      "currency": "USDC",
      "chargeFormula": {
        "language": "exora.price-formula.v4",
        "expression": "delivered * 0.03"
      },
      "maximumChargePerInvocationAtomic": 50000,
      "settlementPolicy": "exora.operation-settlement.v4"
    }
  ]
}
