{
  "name": "exora-dock-desktop",
  "version": "0.1.0-preview.3",
  "description": "Desktop agent workstation for Exora Dock",
  "author": "Exora",
  "homepage": "https://exoradock.com/",
  "desktopName": "exora-dock",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "npm run build:daemon",
    "build:daemon": "node ../scripts/build-desktop-daemon.cjs",
    "dev": "concurrently --restart-tries -1 --restart-after 1000 --names frontend,electron \"npm run dev:frontend\" \"npm run dev:electron\"",
    "preview:desktop": "npm run dev",
    "dev:frontend": "vite --host 127.0.0.1 --port 1420",
    "dev:electron": "wait-on http://127.0.0.1:1420 && electron . --dev-keep-visible",
    "build:frontend": "tsc && vite build",
    "build:electron": "node --test electron/account-activity-scope.test.cjs electron/agent-mcp-registry.test.cjs electron/button-audit.test.cjs electron/app-settings.test.cjs electron/cloud-auth.test.cjs electron/legacy-frontend-cleanup.test.cjs electron/release-manifest.test.cjs electron/ipc.test.cjs electron/network-timeout.test.cjs electron/mcp-connectivity.test.cjs electron/pricing-formula.test.cjs electron/ui-system.test.cjs && node electron/check.cjs",
    "build": "npm run build:frontend && npm run build:electron && electron-builder",
    "build:dmg": "npm run build:frontend && npm run build:electron && electron-builder --mac dmg",
    "build:mac": "npm run build:frontend && npm run build:electron && electron-builder --mac dmg zip --arm64 --publish never -c.mac.identity=- -c.mac.hardenedRuntime=false",
    "build:exe": "npm run build:frontend && npm run build:electron && electron-builder --win nsis --publish never",
    "build:linux": "npm run build:frontend && npm run build:electron && electron-builder --linux AppImage deb --publish never",
    "build:win": "powershell -ExecutionPolicy Bypass -File ../scripts/build-win-docker.ps1",
    "build:win-docker": "powershell -ExecutionPolicy Bypass -File ../scripts/build-win-docker.ps1 -BuildDockerImage"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "lucide": "^1.23.0",
    "qrcode": "^1.5.4",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.0",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "io.exora.dock",
    "productName": "Exora Dock",
    "publish": [
      {
        "provider": "github",
        "owner": "UmbraFi",
        "repo": "exora-dock",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/**/*.test.cjs",
      "!electron/check.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "binaries",
        "to": "binaries",
        "filter": [
          "exora-dockd.exe",
          "exora-dockd"
        ]
      },
      {
        "from": "resources/release-signing-public-key.txt",
        "to": "release-signing-public-key.txt"
      },
      {
        "from": "../LICENSE",
        "to": "legal/LICENSE"
      },
      {
        "from": "../docs/WHITEPAPER.md",
        "to": "legal/WHITEPAPER.md"
      },
      {
        "from": "../docs/WHITEPAPER.en.md",
        "to": "legal/WHITEPAPER.en.md"
      },
      {
        "from": "../skills/prepare-exora-api",
        "to": "skills/prepare-exora-api"
      },
      {
        "from": "../contracts",
        "to": "contracts"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "artifactName": "Exora-Dock-${version}-macOS-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "Exora-Dock-${version}-Windows-x64-Unsigned-Technical-Preview.${ext}"
    },
    "linux": {
      "category": "Development",
      "maintainer": "Exora <omaekumiko2@gmail.com>",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    },
    "appImage": {
      "artifactName": "Exora-Dock-${version}-Linux-x64.${ext}"
    },
    "deb": {
      "artifactName": "Exora-Dock-${version}-Linux-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "allowElevation": true,
      "include": "build/installer.nsh"
    }
  }
}
