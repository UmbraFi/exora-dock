{
  "name": "exora-dock-desktop",
  "version": "0.1.0",
  "description": "Desktop agent workstation for Exora Dock",
  "author": "Exora",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:frontend\" \"wait-on http://127.0.0.1:1420 && electron .\"",
    "preview:desktop": "npm run dev",
    "dev:frontend": "vite --host 127.0.0.1 --port 1420",
    "build:frontend": "tsc && vite build",
    "build:electron": "node --test electron/local-agents.test.cjs electron/resource-archive.test.cjs && node electron/check.cjs",
    "build": "npm run build:frontend && npm run build:electron && electron-builder",
    "build:dmg": "npm run build:frontend && npm run build:electron && electron-builder --mac dmg",
    "build:exe": "npm run build:frontend && npm run build:electron && electron-builder --win nsis",
    "build:linux": "npm run build:frontend && npm run build:electron && electron-builder --linux AppImage deb",
    "build:win": "powershell -ExecutionPolicy Bypass -File ../scripts/build-win-docker.ps1",
    "build:win-docker": "powershell -ExecutionPolicy Bypass -File ../scripts/build-win-docker.ps1 -BuildDockerImage"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "lucide": "^1.23.0",
    "qrcode": "^1.5.4",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1",
    "electron": "^38.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.0",
    "unzipper": "^0.12.5",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "io.exora.dock",
    "productName": "Exora Dock",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "binaries",
        "to": "binaries",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/wsl",
        "to": "wsl",
        "filter": [
          "*.msi",
          "wsl-runtime.lock.json"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "allowElevation": true,
      "include": "build/installer.nsh"
    }
  }
}
